/*
========================================================================================
    Config file for defining DSL2 per module options and publishing paths
========================================================================================
    Available keys to override module options:
        ext.args            = Additional arguments appended to command in module.
        ext.args2           = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3           = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix          = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    withName: BASES2FASTQ {

        // ext.args translates params.b2f_* and shared filter_batch/tile into
        // bases2fastq CLI flags. See upstream README "Module configuration via
        // task.ext.args" for the canonical pattern. Channel-input file paths
        // (run_manifest, panel, tca_manifest, segmentation, analysis_region)
        // are wired in main.nf; the module composes their CLI flags from the
        // staged paths, not here.
        ext.args = {
            def asList = { v -> v instanceof List ? v : (v ? [v] : []) }

            // Tile include/exclude priority:
            //   b2f_include_tile takes priority; falls back to shared `tile` param.
            //   When includes are active, auto-exclude all tiles so includes work as a filter.
            def include_tile_list = asList(params.b2f_include_tile) ?: asList(params.tile)
            def exclude_tile_list = asList(params.b2f_exclude_tile) ?: (include_tile_list ? ['L.R..C..S.'] : [])

            [
                // ── Logging ──────────────────────────────────────────────
                params.b2f_log_level               ? "-l ${params.b2f_log_level}"                : '',
                // ── Boolean toggles ──────────────────────────────────────
                params.b2f_demux_only                     ? '--demux-only'                       : '',
                params.b2f_detect_adapters                ? '--detect-adapters'                  : '',
                params.b2f_error_on_missing               ? '--error-on-missing'                 : '',
                params.b2f_no_error_on_invalid            ? '--no-error-on-invalid'              : '',
                params.b2f_no_projects                    ? '--no-projects'                      : '',
                params.b2f_legacy_fastq                   ? '--legacy-fastq'                     : '',
                params.b2f_qc_only                        ? '--qc-only'                          : '',
                params.b2f_skip_empty_fq_files            ? '--skip-empty-fq-files'              : '',
                params.b2f_skip_multi_qc                  ? '--skip-multi-qc'                    : '',
                params.b2f_skip_qc_report                 ? '--skip-qc-report'                   : '',
                params.b2f_bgzf_compression               ? '--bgzf-compression'                 : '',
                params.b2f_split_lanes                    ? '--split-lanes'                      : '',
                params.b2f_group_fastq                    ? '--group-fastq'                      : '',
                params.b2f_force_detect_index_orientation ? '--force-detect-index-orientation'   : '',
                params.b2f_force_index_orientation        ? '--force-index-orientation'          : '',
                params.b2f_per_target_fastq               ? '--per-target-fastq'                 : '',
                // ── Value flags ──────────────────────────────────────────
                params.b2f_num_unassigned          ? "--num-unassigned ${params.b2f_num_unassigned}"     : '',
                params.b2f_filter_mask             ? "--filter-mask ${params.b2f_filter_mask}"           : '',
                params.b2f_flowcell_id             ? "--flowcell-id ${params.b2f_flowcell_id}"           : '',
                params.b2f_cyto_fastq_mask         ? "--cyto-fastq-mask ${params.b2f_cyto_fastq_mask}"   : '',
                // ── Shared filter ────────────────────────────────────────
                params.filter_batch                ? "--batch ${params.filter_batch}"            : '',
                // ── Tile include/exclude (priority logic above) ──────────
                exclude_tile_list.collect { "--exclude-tile '${it}'" }.join(' '),
                include_tile_list.collect { "--include-tile '${it}'" }.join(' '),
                // ── List flags ───────────────────────────────────────────
                asList(params.b2f_settings).collect { "--settings '${it}'" }.join(' '),
                // ── Deprecated catch-all (use -c custom.config overlay instead) ──
                params.b2f_args ?: '',
            ].findAll().join(' ')
        }

        publishDir = params.disable_task_publish ? [
            path: { "${params.outdir}/" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ] : [
            [
                path: { "${params.outdir}/bases2fastq/" },
                mode: params.publish_dir_mode,
                pattern: "*.{json,csv,html,log}"
            ],
            [
                path: { "${params.outdir}/bases2fastq/" },
                mode: params.publish_dir_mode,
                pattern: "info/*.{log,json}"
            ],
            [
                path: { "${params.outdir}/bases2fastq/" },
                mode: params.publish_dir_mode,
                pattern: "Samples/*/*.{json,fastq.gz,fastq.gz.gzi}"
            ],
            [
                path: { "${params.outdir}/bases2fastq/" },
                mode: params.publish_dir_mode,
                pattern: "Samples/*/*/*.{json,fastq.gz,fastq.gz.gzi}"
            ]
        ]
    }

}
